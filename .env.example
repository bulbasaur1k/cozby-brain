# Стабильное имя docker-compose проекта — с ним контейнеры не пересоздаются
# при переключении между ./run.sh и ./run-docker.sh (и при запуске из
# worktree, где имя каталога отличается).
COMPOSE_PROJECT_NAME=cozby-brain

# -------- Host-порты (можно поменять, если какие-то уже заняты) --------
DB_PORT=5432
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
HTTP_PORT=8081

# -------- Приложение (host-side адресация, для ./run.sh) --------
# Если меняешь host-порт выше — поправь и URL.
DATABASE_URL=postgres://cozby:cozby@localhost:5432/cozby_brain
QDRANT_URL=http://localhost:6334
QDRANT_COLLECTION=cozby_notes
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cozby-attachments

HTTP_ADDR=0.0.0.0:8081
RUST_LOG=info,cozby_brain=debug,tower_http=info

# -------- LLM (OpenAI-compatible chat/completions) --------
LLM_BASE_URL=https://routerai.ru/api/v1
LLM_MODEL=qwen/qwen3-coder-480b-a35b-instruct
LLM_API_KEY=sk-...

# -------- Embedding (для vector search, тот же endpoint) --------
# Для routerai обязательно с префиксом провайдера: openai/, qwen/, google/, …
EMBEDDING_MODEL=openai/text-embedding-3-small

# -------- (опционально) Docker self-hosted overrides --------
# Когда сервер в контейнере, compose по умолчанию использует compose-сеть:
#   DATABASE_URL=postgres://cozby:cozby@db:5432/cozby_brain
#   QDRANT_URL=http://qdrant:6334
#   S3_ENDPOINT=http://minio:9000
# Чтобы указать внешний managed-сервис — раскомментируй и пропиши:
# COZBY_INTERNAL_DB_URL=postgres://user:pass@external:5432/db
# COZBY_INTERNAL_QDRANT_URL=http://external:6334
# COZBY_INTERNAL_S3_ENDPOINT=https://s3.amazonaws.com

# Кастомный Dockerfile / тег образа для self-hosted:
# COZBY_DOCKERFILE=Dockerfile.dev
# COZBY_IMAGE=cozby-brain:dev

# -------- Альтернативные LLM-провайдеры --------
#
# Ollama локально (бесплатно, без ключа):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=
# EMBEDDING_MODEL=nomic-embed-text
#
# OpenRouter (free модели):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
# LLM_API_KEY=sk-or-...
#
# Groq (быстрый free tier):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant
# LLM_API_KEY=gsk_...
